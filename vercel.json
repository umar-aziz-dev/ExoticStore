{
  "version": 2,
  "builds": [
    {
      "src": "api/index.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "/api/index.mjs"
    },
    {
      "src": "/superadmin/(.*)",
      "dest": "/api/index.mjs"
    },
    {
      "src": "/seller/(.*)",
      "dest": "/api/index.mjs"
    },
    {
      "src": "/user/(.*)",
      "dest": "/api/index.mjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}